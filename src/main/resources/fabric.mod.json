      "com.autowaterdrop.client.AutoWaterDropClient"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": "${minecraft_version}"
  },
  "accessWidener": "autowaterdrop.accesswidener",
  "mixins": [
  ]
}

