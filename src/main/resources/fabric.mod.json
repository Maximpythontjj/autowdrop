{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_author}"
  ],
  "license": "${mod_license}",
  "contact": {
    "homepage": "${mod_homepage}"
  },
  "environment": "client",
  "entrypoints": {
